<% return unless current_funcionario.cargo.visualizar_itens? %>

<div id="modal-estoque" class="dash-modal-overlay" data-dashboard-target="modal"
     data-action="click->dashboard#closeOnOverlay">
  <div class="dash-modal-box">
    <div class="dash-modal-header">
      <h2 class="dash-modal-title">📦 Estoque</h2>
    </div>

    <div class="dash-modal-stats">
      <div class="dash-mini-stat">
        <div class="dash-mini-stat-label">Total de itens</div>
        <div class="dash-mini-stat-value"><%= @itens_count %></div>
      </div>
      <div class="dash-mini-stat <%= @itens_estoque_baixo.any? ? "dash-mini-stat--warning" : "" %>">
        <div class="dash-mini-stat-label">Estoque baixo (≤ 10)</div>
        <div class="dash-mini-stat-value"><%= @itens_estoque_baixo.size %></div>
      </div>
      <div class="dash-mini-stat <%= @itens_zerados > 0 ? "dash-mini-stat--danger" : "" %>">
        <div class="dash-mini-stat-label">Zerados</div>
        <div class="dash-mini-stat-value"><%= @itens_zerados %></div>
      </div>
      <div class="dash-mini-stat">
        <div class="dash-mini-stat-label">Valor em estoque</div>
        <div class="dash-mini-stat-value"><%= number_to_currency(@valor_estoque, unit: "R$", separator: ",", delimiter: ".") %></div>
      </div>
    </div>

    <% if @itens_estoque_baixo.any? %>
      <h3 class="dash-modal-section-title">⚠️ Itens com estoque baixo (≤ 10 unidades)</h3>
      <table class="dash-table">
        <thead>
          <tr><th>Item</th><th>Qtd.</th><th>Preço custo</th><th>Preço venda</th></tr>
        </thead>
        <tbody>
          <% @itens_estoque_baixo.each do |item| %>
            <tr>
              <td><%= link_to item.descricao, item_path(item) %></td>
              <td class="<%= item.quantidade_estoque == 0 ? "dash-qty--zero" : "dash-qty--low" %>">
                <%= item.quantidade_estoque %>
              </td>
              <td><%= number_to_currency(item.preco_custo, unit: "R$", separator: ",", delimiter: ".") %></td>
              <td><%= number_to_currency(item.preco_venda, unit: "R$", separator: ",", delimiter: ".") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="dash-estoque-ok">
        ✅ Todos os itens estão com estoque saudável (acima de 10 unidades).
      </div>

      <h3 class="dash-modal-section-title">Itens com menor estoque</h3>
      <table class="dash-table">
        <thead>
          <tr><th>Item</th><th>Qtd.</th><th>Preço venda</th></tr>
        </thead>
        <tbody>
          <% @itens_criticos.each do |item| %>
            <tr>
              <td><%= link_to item.descricao, item_path(item) %></td>
              <td><%= item.quantidade_estoque %></td>
              <td><%= number_to_currency(item.preco_venda, unit: "R$", separator: ",", delimiter: ".") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>

    <%= link_to "Ver estoque completo →", itens_path, class: "dash-modal-cta" %>
  </div>
</div>
