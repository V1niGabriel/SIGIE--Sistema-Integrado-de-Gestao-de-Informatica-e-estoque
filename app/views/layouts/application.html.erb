<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Sigie Sistema Integrado De Gestao De Informatica E Estoque" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Sigie Sistema Integrado De Gestao De Informatica E Estoque">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon_logo.png" type="image/png">
    <link rel="icon" href="/icon_logo.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <% if funcionario_signed_in? %>
      <div class="app-layout">
        
        <aside class="sidebar">
          <div class="sidebar-logo">
            <div class="sidebar-logo">
              <%= image_tag "Logo_SIGIE-transparente.png", alt: "Logo SIGIE" %>
            </div>
          </div>

          <nav class="sidebar-nav">
            <div class="nav-group">
              <div class="nav-title">Principal</div>
              <%= link_to "Início / Vendas", root_path, class: "nav-link" %>
              <%= link_to "Orçamentos", orcamentos_path, class: "nav-link" %>
            </div>

            <div class="nav-group">
              <div class="nav-title">Cadastros</div>
              <%= link_to "Clientes", clientes_path, class: "nav-link" %>
              <%= link_to "Estoque (Itens)", itens_path, class: "nav-link" %>
            </div>

            <div class="nav-group">
              <div class="nav-title">Gestão de Compras</div>
              <%= link_to "Compras", compras_path, class: "nav-link" %>
              <%= link_to "Fornecedores", fornecedores_path, class: "nav-link" %>
              <%= link_to "Fabricantes", fabricantes_path, class: "nav-link" %>
              <%= link_to "Categorias", categorias_path, class: "nav-link" %>
            </div>

            <div class="nav-group">
              <div class="nav-title">Administração</div>
              <%= link_to "Mov. de Estoque", movimentacao_estoques_path, class: "nav-link" %>
              <%= link_to "Funcionários", funcionarios_path, class: "nav-link" %>
              <%= link_to "Cargos", cargos_path, class: "nav-link" %>
              <%= link_to "Dados da Empresa", dados_empresas_path, class: "nav-link" %>
            </div>
          </nav>
        </aside>

        <div class="main-content-wrapper">
          
          <header class="topbar">
            <div class="user-profile">
              <div class="user-info">
                <div class="user-name"><%= current_funcionario.nome %></div>
                <div class="user-role"><%= current_funcionario.cargo.titulo %></div>
              </div>
              <%= button_to "Sair", destroy_funcionario_session_path, method: :delete, class: "btn-logout" %>
            </div>
          </header>

          <main style="flex: 1; overflow-y: auto;">
            <%= yield %>
          </main>
          
        </div>
      </div>

    <% else %>
      <%= yield %>
    <% end %>
  </body>
</html>