<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Sigie Sistema Integrado De Gestao De Informatica E Estoque" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Sigie Sistema Integrado De Gestao De Informatica E Estoque">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon_logo.png" type="image/png">
    <link rel="icon" href="/icon_logo.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <% if funcionario_signed_in? %>
      <!-- Criamos um atalho para não ter que digitar isso 20 vezes -->
      <% cargo = current_funcionario.cargo %>

      <div class="app-layout">
        
        <aside class="sidebar">
          <div class="sidebar-logo">
            <%= image_tag "Logo_SIGIE-transparente.png", alt: "Logo SIGIE" %>
          </div>

          <nav class="sidebar-nav">
            
            <!-- GRUPO: PRINCIPAL -->
            <div class="nav-group">
              <div class="nav-title">Principal</div>
              <%= link_to "Início", root_path, class: "nav-link" %>
              <% if cargo.visualizar_vendas? %>
                <%= link_to "Vendas", vendas_path, class: "nav-link" %>
              <% end %>
              <% if cargo.visualizar_orcamentos? %>
                <%= link_to "Orçamentos", orcamentos_path, class: "nav-link" %>
              <% end %>
            </div>

            <!-- GRUPO: CADASTROS -->
            <% if cargo.visualizar_clientes? || cargo.visualizar_itens? %>
              <div class="nav-group">
                <div class="nav-title">Cadastros</div>
                <% if cargo.visualizar_clientes? %>
                  <%= link_to "Clientes", clientes_path, class: "nav-link" %>
                <% end %>
                <% if cargo.visualizar_itens? %>
                  <%= link_to "Estoque (Itens)", itens_path, class: "nav-link" %>
                <% end %>
              </div>
            <% end %>

            <!-- GRUPO: GESTÃO DE COMPRAS -->
            <% if cargo.visualizar_compras? || cargo.visualizar_fornecedores? || cargo.visualizar_fabricantes? || cargo.visualizar_categorias? %>
              <div class="nav-group">
                <div class="nav-title">Gestão de Compras</div>
                <% if cargo.visualizar_compras? %>
                  <%= link_to "Compras", compras_path, class: "nav-link" %>
                <% end %>
                <% if cargo.visualizar_fornecedores? %>
                  <%= link_to "Fornecedores", fornecedores_path, class: "nav-link" %>
                <% end %>
                <% if cargo.visualizar_fabricantes? %>
                  <%= link_to "Fabricantes", fabricantes_path, class: "nav-link" %>
                <% end %>
                <% if cargo.visualizar_categorias? %>
                  <%= link_to "Categorias", categorias_path, class: "nav-link" %>
                <% end %>
              </div>
            <% end %>

            <!-- GRUPO: ADMINISTRAÇÃO -->
            <% if cargo.visualizar_movimentacoes? || cargo.visualizar_funcionarios? || cargo.visualizar_cargos? || cargo.visualizar_empresa? %>
              <div class="nav-group">
                <div class="nav-title">Administração</div>
                <% if cargo.visualizar_movimentacoes? %>
                  <%= link_to "Mov. de Estoque", movimentacao_estoques_path, class: "nav-link" %>
                <% end %>
                <% if cargo.visualizar_funcionarios? %>
                  <%= link_to "Funcionários", funcionarios_path, class: "nav-link" %>
                <% end %>
                <% if cargo.visualizar_cargos? %>
                  <%= link_to "Cargos", cargos_path, class: "nav-link" %>
                <% end %>
                <% if cargo.visualizar_empresa? %>
                  <%= link_to "Dados da Empresa", dados_empresas_path, class: "nav-link" %>
                <% end %>
              </div>
            <% end %>

          </nav>
        </aside>

        <div class="main-content-wrapper">
          
          <header class="topbar">
            <div class="user-profile">
              <div class="user-info">
                <div class="user-name"><%= current_funcionario.nome %></div>
                <div class="user-role"><%= current_funcionario.cargo.titulo %></div>
              </div>
              <%= button_to "Sair", destroy_funcionario_session_path, method: :delete, class: "btn-logout" %>
            </div>
          </header>

          <main style="flex: 1; overflow-y: auto;">
            <%= yield %>
          </main>
          
        </div>
      </div>

    <% else %>
      <%= yield %>
    <% end %>
  </body>
</html>