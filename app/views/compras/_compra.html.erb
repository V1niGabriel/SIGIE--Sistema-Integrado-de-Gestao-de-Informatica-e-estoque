<div id="<%= dom_id compra %>">
  <div>
    <strong>Fornecedor:</strong>
    <%= compra.fornecedor_id %>
  </div>

  <div>
    <strong>Itens:</strong>
    <%= compra.itens_compra.map { |ic| "#{ic.item.descricao} (#{ic.quantidade}x)" }.join(", ") %>
  </div>

  <div>
    <strong>Valor total:</strong>
    <%= compra.valor_total %>
  </div>

  <div>
    <strong>Data vencimento:</strong>
    <%= compra.data_vencimento %>
  </div>

  <div>
    <strong>Status:</strong>
    <%= compra.status %>
  </div>

</div>
