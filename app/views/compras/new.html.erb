<% content_for :title, "Nova Compra" %>

<div class="dashboard-container" data-controller="compra"
     data-compra-items-value="<%= @itens.map { |i| { id: i.id, descricao: i.descricao, preco_custo: i.preco_custo.to_f, estoque: i.quantidade_estoque } }.to_json %>">
  <div class="page-header">
    <h1 class="page-title">Registrar Nova Compra</h1>
  </div>

  <div class="card">
    <%= render "form", compra: @compra %>
  </div>
</div>
