<div class="login-page-wrapper">
  <div class="left-panel">
    <div class="top-section">
      <%= link_to "O que há de novo?", "#", class: "whats-new-btn" %>
    </div>

    <div class="middle-section">
      <div class="image-placeholder">
        <span>[Espaço para a imagens do projeto]</span>
      </div>
    </div>

    <div class="bottom-section">
      <div class="pagination-lines">
        <div class="line"></div>
        <div class="line"></div>
        <div class="line active"></div>
        <div class="line"></div>
      </div>
    </div>
  </div>

  <div class="right-panel">
    <div class="header-actions">
      <div class="language-selector">
        🇧🇷 Português ▾
      </div>
      <div class="theme-toggle">🌙</div>
    </div>

    <div class="login-container">
      <div class="logo-space">
        <h2>[Sua Logo Aqui]</h2>
      </div>
      
      <h1>Entre em sua conta</h1>
      <p>Ofereça experiências incríveis aos seus clientes</p>

      <%= form_with url: "#", local: true, class: "login-form" do |f| %>
        <div class="form-group">
          <%= f.email_field :email, placeholder: "E-mail", required: true %>
        </div>
        
        <div class="form-group">
          <%= f.password_field :password, placeholder: "Senha", required: true %>
          <span class="eye-icon"></span>
        </div>

        <div class="form-options">
          <label>
            <%= f.check_box :remember_me %> Lembrar e-mail
          </label>
          <%= link_to "Esqueceu sua senha?", "#", class: "forgot-password" %>
        </div>

        <%= f.submit "Entrar", class: "btn-submit" %>

      <% end %>
    </div>
  </div>
</div>