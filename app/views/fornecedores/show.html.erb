<div class="dashboard-container">
  <div class="page-header">
    <h1 class="page-title">Ficha do Fornecedor</h1>
    <div style="display: flex; gap: 10px;">
      <%= link_to "← Voltar", fornecedores_path, class: "btn-secondary" %>
      <%= link_to "Editar Fornecedor", edit_fornecedor_path(@fornecedor), class: "btn-primary" %>
    </div>
  </div>

  <div class="card detail-card">
    <div style="margin-bottom: 30px; padding-bottom: 20px; border-bottom: 1px solid #e5e7eb;">
      <h2 style="margin: 0 0 10px 0; color: #1f2937; font-size: 1.5rem;"><%= @fornecedor.nome %></h2>
      <span class="badge-stock" style="background-color: #fce7f3; color: #9d174d;">Parceiro Comercial</span>
    </div>

    <div class="detail-grid">
      <div class="detail-item">
        <span class="detail-label">CNPJ</span>
        <span class="detail-value"><%= @fornecedor.cnpj %></span>
      </div>

      <div class="detail-item">
        <span class="detail-label">E-mail Comercial</span>
        <span class="detail-value"><%= @fornecedor.email %></span>
      </div>

      <div class="detail-item">
        <span class="detail-label">Telefone</span>
        <span class="detail-value"><%= @fornecedor.telefone %></span>
      </div>
    </div>

    <div style="margin-top: 20px; text-align: right;">
      <%= button_to "Excluir Fornecedor", @fornecedor, method: :delete, data: { turbo_confirm: "Tem certeza que deseja remover este fornecedor? Produtos e compras associadas a ele podem gerar erros se não forem reatribuídos." }, class: "btn-secondary", style: "color: #ef4444; border-color: #fca5a5;" %>
    </div>
  </div>
</div>