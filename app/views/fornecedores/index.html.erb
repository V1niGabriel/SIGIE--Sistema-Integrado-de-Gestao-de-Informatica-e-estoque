<div class="dashboard-container">
  
  <div class="page-header">
    <h1 class="page-title">Fornecedores</h1>
    <%= link_to "+ Adicionar Fornecedor", new_fornecedor_path, class: "btn-primary" %>
  </div>

  <div class="card">
    <table class="data-table">
      <thead>
        <tr>
          <th>Nome Fantasia / Razão Social</th>
          <th>CNPJ</th>
          <th>E-mail</th>
          <th>Telefone</th>
          <th>Ações</th>
        </tr>
      </thead>
      <tbody>
        <% if @fornecedores.any? %>
          <% @fornecedores.each do |fornecedor| %>
            <tr>
              <td><strong><%= fornecedor.nome %></strong></td>
              <td><%= fornecedor.cnpj %></td>
              <td><%= fornecedor.email %></td>
              <td><%= fornecedor.telefone %></td>
              <td class="action-links">
                <%= link_to "Ver Detalhes", fornecedor %>
                <%= link_to "Editar", edit_fornecedor_path(fornecedor) %>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="5" style="text-align: center; padding: 40px; color: #6b7280;">
              Nenhum fornecedor cadastrado.
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

</div>