<%= form_with(model: fornecedor, class: "form-content") do |form| %>
  <% if fornecedor.errors.any? %>
    <div style="background: #fee2e2; color: #991b1b; padding: 15px; border-radius: 8px; margin-bottom: 20px;">
      <strong>Não foi possível salvar:</strong>
      <ul style="margin-top: 10px; margin-bottom: 0;">
        <% fornecedor.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-grid full">
    <div>
      <%= form.label :nome, "Nome do Fornecedor / Empresa", class: "form-label" %>
      <%= form.text_field :nome, class: "form-input", placeholder: "Ex: Distribuidora Tech S/A", required: true %>
    </div>
  </div>

  <div class="form-grid">
    <div>
      <%= form.label :cnpj, "CNPJ (Apenas números)", class: "form-label" %>
      <%= form.text_field :cnpj, class: "form-input", placeholder: "Ex: 12345678000190", maxlength: 14, required: true %>
    </div>

    <div>
      <%= form.label :email, "E-mail de Contato", class: "form-label" %>
      <%= form.email_field :email, class: "form-input", placeholder: "Ex: vendas@fornecedor.com", required: true %>
    </div>

    <div>
      <%= form.label :telefone, "Telefone / WhatsApp", class: "form-label" %>
      <%= form.text_field :telefone, class: "form-input", placeholder: "Ex: 11988887777", maxlength: 11, required: true %>
    </div>
  </div>

  <div class="form-actions">
    <%= link_to "Cancelar", fornecedores_path, class: "btn-secondary" %>
    <%= form.submit "Salvar Fornecedor", class: "btn-primary" %>
  </div>
<% end %>