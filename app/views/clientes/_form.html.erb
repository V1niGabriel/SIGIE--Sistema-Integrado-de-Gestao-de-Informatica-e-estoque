<%= form_with(model: cliente, class: "form-content", data: { controller: "cliente-form" }) do |form| %>
  <% if cliente.errors.any? %>
    <div style="background: #fee2e2; color: #991b1b; padding: 15px; border-radius: 8px; margin-bottom: 20px;">
      <strong>Não foi possível salvar:</strong>
      <ul style="margin-top: 10px; margin-bottom: 0;">
        <% cliente.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-grid full">
    <div>
      <%= form.label :nome_razao_social, "Nome Completo ou Razão Social", class: "form-label" %>
      <%= form.text_field :nome_razao_social, class: "form-input", placeholder: "Ex: João da Silva ou Empresa XYZ Ltda", required: true %>
    </div>
  </div>

  <div class="form-grid">
    <%# NOVO: Seleção do Tipo de Pessoa %>
    <div>
      <label class="form-label">Tipo de Cliente</label>
      <select class="form-input" data-cliente-form-target="tipo" data-action="change->cliente-form#toggleTipo">
        <%# Mantém a seleção correta ao editar um cliente existente %>
        <option value="pf" <%= 'selected' if cliente.cpf_cnpj.to_s.length <= 14 %>>Pessoa Física</option>
        <option value="pj" <%= 'selected' if cliente.cpf_cnpj.to_s.length > 14 %>>Pessoa Jurídica</option>
      </select>
    </div>

    <%# ATUALIZADO: Documento dinâmico controlado pelo JavaScript %>
    <div>
      <%= form.label :cpf_cnpj, "CPF (Opcional)", class: "form-label", data: { cliente_form_target: "documentoLabel" } %>
      <%= form.text_field :cpf_cnpj, 
            class: "form-input", 
            data: { 
              cliente_form_target: "documentoInput",
              action: "input->cliente-form#formatarDocumento blur->cliente-form#validarDocumento"
            } %>
      <small data-cliente-form-target="erro" style="color: #ef4444; display: none; margin-top: 5px; font-weight: 600;"></small>
    </div>

    <div>
      <%= form.label :email, "E-mail de Contato", class: "form-label" %>
      <%= form.email_field :email, class: "form-input", placeholder: "Ex: contato@cliente.com", required: true %>
    </div>

    <div>
      <%= form.label :telefone, "Telefone / WhatsApp", class: "form-label" %>
      <%= form.text_field :telefone, class: "form-input", placeholder: "Ex: 11999999999", maxlength: 11, required: true %>
    </div>
  </div>

  <div class="form-actions">
    <%= link_to "Cancelar", clientes_path, class: "btn-secondary" %>
    <%= form.submit "Salvar Cliente", class: "btn-primary" %>
  </div>
<% end %>