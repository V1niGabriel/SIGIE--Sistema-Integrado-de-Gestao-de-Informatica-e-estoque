<%= form_with(model: cliente, class: "form-content") do |form| %>
  <% if cliente.errors.any? %>
    <div style="background: #fee2e2; color: #991b1b; padding: 15px; border-radius: 8px; margin-bottom: 20px;">
      <strong>Não foi possível salvar:</strong>
      <ul style="margin-top: 10px; margin-bottom: 0;">
        <% cliente.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-grid full">
    <div>
      <%= form.label :nome_razao_social, "Nome Completo ou Razão Social", class: "form-label" %>
      <%= form.text_field :nome_razao_social, class: "form-input", placeholder: "Ex: João da Silva ou Empresa XYZ Ltda", required: true %>
    </div>
  </div>

  <div class="form-grid">
    <div>
      <%= form.label :cpf_cnpj, "CPF ou CNPJ (Apenas números)", class: "form-label" %>
      <%= form.text_field :cpf_cnpj, class: "form-input", placeholder: "Ex: 12345678900", maxlength: 14, required: true %>
    </div>

    <div>
      <%= form.label :email, "E-mail de Contato", class: "form-label" %>
      <%= form.email_field :email, class: "form-input", placeholder: "Ex: contato@cliente.com", required: true %>
    </div>

    <div>
      <%= form.label :telefone, "Telefone / WhatsApp", class: "form-label" %>
      <%= form.text_field :telefone, class: "form-input", placeholder: "Ex: 11999999999", maxlength: 11, required: true %>
    </div>
  </div>

  <div class="form-actions">
    <%= link_to "Cancelar", clientes_path, class: "btn-secondary" %>
    <%= form.submit "Salvar Cliente", class: "btn-primary" %>
  </div>
<% end %>