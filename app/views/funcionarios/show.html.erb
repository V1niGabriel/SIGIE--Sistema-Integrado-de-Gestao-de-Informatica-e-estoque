<div class="dashboard-container">
  <div class="page-header">
    <h1 class="page-title">Detalhes do Funcionário</h1>
    <div style="display: flex; gap: 10px;">
      <%= link_to "Voltar", funcionarios_path, class: "btn-secondary" %>
      <%= link_to "Editar", edit_funcionario_path(@funcionario), class: "btn-primary" %>
      <%= button_to "Excluir", @funcionario, method: :delete, class: "btn-danger", form: { style: "display: inline-block;" } %>
    </div>
  </div>

  <% if notice.present? %>
    <p style="color: #065f46; background-color: #d1fae5; padding: 10px; border-radius: 8px;"><%= notice %></p>
  <% end %>

  <div class="card detail-card">
    <%= render @funcionario %>
  </div>
</div>