<div id="<%= dom_id funcionario %>" class="detail-grid">
  <div class="detail-item">
    <span class="detail-label">Nome Completo</span>
    <span class="detail-value"><%= funcionario.nome %></span>
  </div>

  <div class="detail-item">
    <span class="detail-label">CPF</span>
    <span class="detail-value"><%= funcionario.cpf %></span>
  </div>

  <div class="detail-item">
    <span class="detail-label">E-mail</span>
    <span class="detail-value"><%= funcionario.email %></span>
  </div>

  <div class="detail-item">
    <span class="detail-label">Telefone</span>
    <span class="detail-value"><%= funcionario.telefone %></span>
  </div>

  <div class="detail-item">
    <span class="detail-label">Cargo (ID)</span>
    <span class="detail-value"><%= funcionario.cargo_id %></span>
  </div>

  <div class="detail-item">
    <span class="detail-label">Data de Admissão</span>
    <span class="detail-value"><%= funcionario.data_admissao&.strftime("%d/%m/%Y") %></span>
  </div>
</div>